# ─────────────────────────────────────────
# 塗装会社専用AI積算・見積りシステム 環境設定
# ─────────────────────────────────────────
# このファイルをコピーして .env にリネームし、値を設定してください
# cp .env.example .env

# OpenAI APIキー（必須）
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用するOpenAIモデル（変更可能）
# gpt-4o（推奨）/ gpt-4o-mini（低コスト）/ gpt-4-turbo
OPENAI_MODEL=gpt-4o

# 会社情報（見積書に印刷される）
COMPANY_NAME=株式会社〇〇塗装
COMPANY_ADDRESS=〇〇県〇〇市〇〇町1-2-3
COMPANY_TEL=000-000-0000
COMPANY_FAX=000-000-0000

# 見積書の有効期限（日数）
QUOTE_VALID_DAYS=30

# 消費税率
TAX_RATE=0.10

# デフォルト粗利率（0〜1）
DEFAULT_PROFIT_MARGIN=0.25
